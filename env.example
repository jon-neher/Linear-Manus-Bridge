LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://localhost:3000/oauth/callback
LINEAR_WEBHOOK_SECRET=
MANUS_API_KEY=
INSTALLATION_STORE_SECRET=
MANUS_API_URL=https://api.manus.im/v1/tasks

# SERVICE_BASE_URL is used to reconstruct the full webhook URL for RSA-SHA256
# signature verification. Set this to your production deployment URL (no trailing slash).
# Example: https://linear-manus-bridge-production.up.railway.app
SERVICE_BASE_URL=

# DATA_DIR sets the directory where persistent data files are stored.
# On Railway, add a Volume mounted at /data and set DATA_DIR=/data so that
# OAuth tokens and state survive deployments and restarts.
# Defaults to the process working directory if not set (not persistent on Railway).
DATA_DIR=/data

LINEAR_COMPLETION_STATE=Done
LINEAR_FAILURE_STATE=Cancelled
LINEAR_IN_PROGRESS_STATE=In Progress
LINEAR_NEEDS_INPUT_STATE=Needs Input
MANUS_AGENT_PROFILE=manus-1.6
MANUS_TASK_MODE=agent

# CANDIDATE_REPOSITORIES is a comma-separated list of GitHub repositories
# that may be relevant to issues. Used with Linear's repository suggestions API
# to rank relevance. Example: github.com/owner/repo1,github.com/owner/repo2
CANDIDATE_REPOSITORIES=

# MANUS_AUTH_URL is the URL users will be directed to for linking their
# GitHub account with Manus. If set, auth-related errors from Manus will
# trigger an auth elicitation in Linear showing a "Link Account" button.
# Example: https://manus.ai/settings/integrations/github
MANUS_AUTH_URL=
